{
  "compilerOptions": {
    "types": ["node", "jest"],
    "target": "ESNext",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"]
}
